# ---------------------------------------------------------------
# Server configuration
# ---------------------------------------------------------------
PORT=5000

# The exact origin of the React dev server / production frontend.
# CORS will ONLY allow requests from this origin.
REACT_APP_URL="http://localhost:5174"

# ---------------------------------------------------------------
# Google Sheets (Service Account) credentials
# ---------------------------------------------------------------
# 1. Create a project at https://console.cloud.google.com
# 2. Enable the "Google Sheets API"
# 3. Create a Service Account + JSON key
# 4. Share your spreadsheet with the service account email (Editor access)
GOOGLE_SPREADSHEET_ID="your_actual_spreadsheet_id"
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"

# Keep the private key wrapped in quotes; the code converts the escaped \n
# sequences back into real newlines.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBg...\n-----END PRIVATE KEY-----\n"

# Sheet tab name that holds the registration rows
GOOGLE_SHEET_NAME="Sheet1"
